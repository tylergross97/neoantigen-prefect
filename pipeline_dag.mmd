%%metro title: Neoantigen Prediction Pipeline
%%metro style: dark
%%metro line: variants | Variant Analysis | #F59E0B
%%metro line: expression | Expression | #3B82F6
%%metro line: hla | HLA Typing | #8B5CF6
%%metro line: neoantigen | Neoantigen | #10B981

graph LR
    subgraph inputs [Inputs]
        wes["WES FASTQs\n(tumor + normal)"]
        rna["RNA-seq FASTQs\n(tumor)"]
    end

    subgraph nfcore [nf-core Pipelines]
        sarek["1 · nf-core/sarek\nMutect2 · CNVkit · VEP"]
        hlatyping["2 · nf-core/hlatyping\nOptiType — normal reads"]
        rnaseq["3 · nf-core/rnaseq\nSTAR-Salmon"]
    end

    subgraph annotation [Annotation]
        vcfannot["4 · vcf-expression-annotator\nannotate VCF with TPM"]
        purecn["6 · nextflow-purecn\ntumor purity & CCF"]
    end

    subgraph prediction [Prediction & Output]
        epipred["5 · nf-core/epitopeprediction\nMHC-I binding predictions"]
        postproc["7+8 · post-processing\nmerge · join CCF · prioritise"]
        out["Prioritised Neoantigens\nS3 output"]
    end

    wes -->|variants| sarek
    wes -->|hla| hlatyping
    rna -->|expression| rnaseq
    sarek -->|"variants,expression"| vcfannot
    sarek -->|variants| purecn
    rnaseq -->|expression| vcfannot
    vcfannot -->|"variants,hla"| epipred
    hlatyping -->|hla| epipred
    epipred -->|neoantigen| postproc
    vcfannot -->|neoantigen| postproc
    purecn -->|neoantigen| postproc
    postproc -->|neoantigen| out
